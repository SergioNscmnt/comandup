<!DOCTYPE html>
<html>
  <head>
    <title>ComandUp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= favicon_link_tag "/comandup-favicon.svg", type: "image/svg+xml" %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <div class="page-bg"></div>
    <%= render "shared/toast_area" %>

    <header class="app-header">
      <div class="container-fluid app-nav">
        <%= link_to root_path, class: "brand" do %>
          <%= image_tag "/comandup-favicon.svg", alt: "", class: "brand-icon", aria: { hidden: true } %>
          <span>ComandUp</span>
        <% end %>

        <details class="nav-accordion" data-controller="nav-accordion">
          <summary class="icon-link nav-accordion__trigger">
            <%= ui_icon(:list) %>
            <span>Menu</span>
          </summary>

          <nav class="nav-links">
            <%= render "shared/nav_cart" %>

            <%= link_to products_path, class: "icon-link" do %>
              <%= ui_icon(:box) %>
              <span>Produtos</span>
            <% end %>

            <% if current_customer %>
              <%= link_to orders_path, class: "icon-link" do %>
                <%= ui_icon(:receipt) %>
                <span>Meus pedidos</span>
              <% end %>
              <%= link_to account_path, class: "icon-link" do %>
                <%= ui_icon(:user) %>
                <span>Minha conta</span>
              <% end %>
              <%= button_to customer_logout_path, method: :delete, class: "icon-link nav-action-link" do %>
                <%= ui_icon(:logout) %>
                <span>Sair cliente</span>
              <% end %>
            <% end %>

            <% if current_admin %>
              <%= link_to admin_dashboard_path, class: "icon-link" do %>
                <%= ui_icon(:chart) %>
                <span>Dashboard</span>
              <% end %>
              <%= link_to admin_queue_path, class: "icon-link" do %>
                <%= ui_icon(:list) %>
                <span>Fila de Pedidos</span>
              <% end %>
              <%= link_to edit_admin_company_profile_path, class: "icon-link" do %>
                <%= ui_icon(:receipt) %>
                <span>Empresa</span>
              <% end %>
              <%= button_to admin_logout_path, method: :delete, class: "icon-link nav-action-link" do %>
                <%= ui_icon(:logout) %>
                <span>Sair</span>
              <% end %>
            <% end %>

            <% unless current_customer || current_admin %>
              <details class="nav-auth-dropdown">
                <summary class="icon-link nav-auth-trigger">
                  <%= ui_icon(:login) %>
                  <span>Entrar</span>
                </summary>
                <div class="nav-auth-menu">
                  <%= link_to customer_login_path, class: "icon-link" do %>
                    <%= ui_icon(:login) %>
                    <span>Área do Cliente</span>
                  <% end %>
                  <%= link_to admin_login_path, class: "icon-link" do %>
                    <%= ui_icon(:login) %>
                    <span>Área Administrativa</span>
                  <% end %>
                </div>
              </details>
            <% end %>
          </nav>
        </details>
      </div>
    </header>

    <main class="app-main">
      <%= yield %>
    </main>
  </body>
</html>
