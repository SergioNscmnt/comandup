<div class="container py-4 py-lg-5">
  <section class="hero-card fade-in-up auth-card mx-auto">
    <p class="eyebrow mb-1">Acesso do cliente</p>
    <h1 class="h3 mb-2"><%= ui_icon(:login) %> Redefinir senha</h1>
    <p class="text-secondary mb-4">Escolha uma nova senha para sua conta.</p>

    <%= form_with model: resource, as: resource_name, url: user_password_path, method: :put, local: true do |f| %>
      <%= f.hidden_field :reset_password_token %>

      <div class="mb-2" data-controller="password-visibility">
        <div class="input-group">
          <%= f.password_field :password, class: "form-control", required: true, autocomplete: "new-password", minlength: 8, placeholder: "Nova senha (min. 8 caracteres)", data: { password_visibility_target: "input" } %>
          <button type="button" class="btn btn-outline-brand icon-btn justify-content-center" data-password-visibility-target="button" data-action="password-visibility#toggle" aria-label="Mostrar senha" title="Mostrar senha">
            <span data-password-visibility-target="showIcon"><%= ui_icon(:eye) %></span>
            <span data-password-visibility-target="hideIcon" hidden><%= ui_icon(:eye_slash) %></span>
          </button>
        </div>
      </div>

      <div class="mb-3" data-controller="password-visibility">
        <div class="input-group">
          <%= f.password_field :password_confirmation, class: "form-control", required: true, autocomplete: "new-password", minlength: 8, placeholder: "Confirmar nova senha", data: { password_visibility_target: "input" } %>
          <button type="button" class="btn btn-outline-brand icon-btn justify-content-center" data-password-visibility-target="button" data-action="password-visibility#toggle" aria-label="Mostrar senha" title="Mostrar senha">
            <span data-password-visibility-target="showIcon"><%= ui_icon(:eye) %></span>
            <span data-password-visibility-target="hideIcon" hidden><%= ui_icon(:eye_slash) %></span>
          </button>
        </div>
      </div>

      <div class="d-grid">
        <button type="submit" class="btn btn-brand icon-btn justify-content-center">
          <%= ui_icon(:check) %>
          <span>Atualizar senha</span>
        </button>
      </div>
    <% end %>
  </section>
</div>
