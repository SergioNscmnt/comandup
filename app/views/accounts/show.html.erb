<div class="container py-4 py-lg-5">
  <section class="section-head fade-in-up d-flex justify-content-between align-items-end gap-3 flex-wrap">
    <div>
      <p class="eyebrow mb-1">Minha conta</p>
      <h1 class="h2 mb-1"><%= ui_icon(:user) %> Perfil do cliente</h1>
      <p class="text-secondary mb-0">Gerencie seus dados e acompanhe seu histórico.</p>
    </div>
    <%= link_to orders_path, class: "btn btn-outline-brand icon-btn" do %>
      <%= ui_icon(:receipt) %>
      <span>Meus pedidos</span>
    <% end %>
  </section>

  <section class="row g-3 mt-2">
    <div class="col-12 col-md-4">
      <article class="metric-card fade-in-up fade-delay-1">
        <small>Total de pedidos</small>
        <strong><%= ui_icon(:list) %> <%= @orders_count %></strong>
      </article>
    </div>
    <div class="col-12 col-md-4">
      <article class="metric-card fade-in-up fade-delay-2">
        <small>Pedidos ativos</small>
        <strong><%= ui_icon(:clock) %> <%= @active_orders_count %></strong>
      </article>
    </div>
    <div class="col-12 col-md-4">
      <article class="metric-card fade-in-up fade-delay-3">
        <small>Último pedido</small>
        <strong>
          <%= ui_icon(:receipt) %>
          <%= @last_order ? l(@last_order.created_at, format: :short) : "-" %>
        </strong>
      </article>
    </div>
  </section>

  <section class="hero-card mt-3 fade-in-up">
    <h2 class="h5 mb-3"><%= ui_icon(:user) %> Dados cadastrais</h2>
    <%= form_with model: @customer, url: account_path, method: :patch, local: true do |f| %>
      <div class="row g-3">
        <div class="col-12 col-md-6">
          <%= f.label :name, "Nome", class: "form-label" %>
          <%= f.text_field :name, class: "form-control", required: true %>
        </div>
        <div class="col-12 col-md-6">
          <%= f.label :email, "E-mail", class: "form-label" %>
          <%= f.email_field :email, class: "form-control", required: true %>
        </div>
      </div>
      <div class="d-flex flex-wrap gap-2 mt-3">
        <%= f.button class: "btn btn-brand icon-btn" do %>
          <%= ui_icon(:check) %>
          <span>Salvar alterações</span>
        <% end %>
        <%= link_to new_user_password_path, class: "btn btn-outline-brand icon-btn" do %>
          <%= ui_icon(:lock) %>
          <span>Trocar senha</span>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
