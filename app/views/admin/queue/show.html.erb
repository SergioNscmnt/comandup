<div class="container py-4 py-lg-5">
  <section class="section-head fade-in-up d-flex flex-wrap justify-content-between gap-3 align-items-end">
    <div>
      <p class="eyebrow mb-1">Operação</p>
      <h1 class="h2 mb-1"><%= ui_icon(:list) %> Fila de produção</h1>
      <p class="text-secondary mb-0">Ordenação FIFO com prioridade visual para os pedidos mais antigos.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
      <%= form_with url: admin_queue_path, method: :get, local: true, class: "d-flex align-items-center gap-2" do %>
        <label for="order_type" class="mb-0 text-secondary">Tipo:</label>
        <%= select_tag :order_type, options_for_select([["Todos", ""], ["Mesa", "table"], ["Retirada", "pickup"], ["Delivery", "delivery"]], @filter), class: "form-select form-select-sm", onchange: "this.form.submit()" %>
      <% end %>
      <div class="queue-count">
        <span><%= @orders.size %></span>
        <small>em aberto</small>
      </div>
    </div>
  </section>

  <section class="queue-list mt-3">
    <% @orders.each_with_index do |order, index| %>
      <article class="queue-card queue-card--admin fade-in-up" style="animation-delay:<%= (index % 8) * 0.04 %>s">
        <div class="queue-card-top">
          <div class="queue-left">
            <span class="queue-rank">#<%= order.queue_position || index + 1 %></span>
            <h2 class="h6 mb-0"><%= ui_icon(:receipt) %> Pedido #<%= order.id %></h2>
          </div>

          <div class="queue-meta">
            <span class="status-pill status-<%= order.status %>"><%= ui_icon(:check) %> <%= order.human_status %></span>
            <span class="prep-chip prep-chip--eta"><%= ui_icon(:clock) %> Tempo estimado de preparo: <%= order.eta_minutes || '-' %> min</span>
          </div>
        </div>

        <div class="queue-card-body">
          <section class="queue-section">
            <p class="section-title mb-1">Dados do pedido</p>
            <p class="text-secondary mb-1"><strong>Criado em:</strong> <%= l(order.created_at, format: :short) %></p>
            <p class="text-secondary mb-1">
              <strong>Tipo:</strong> <%= order.human_order_type %>
              <% if order.order_type_table? %>
                | <strong>Mesa:</strong> <%= order.table_number %>
              <% end %>
            </p>
            <% if order.customer.present? %>
              <p class="text-secondary mb-1"><strong>Cliente:</strong> <%= order.customer.name %> (<%= order.customer.email %>)</p>
            <% end %>
            <% if order.order_type_delivery? && order.delivery_address.present? %>
              <p class="text-secondary mb-1"><strong>Endereço:</strong> <%= order.delivery_address %></p>
            <% end %>
            <p class="text-secondary mb-0"><strong>Total:</strong> <span class="fact-value--total"><%= money(order.total_cents) %></span></p>
          </section>

          <section class="queue-section">
            <p class="section-title mb-1">Itens do pedido</p>
            <ul class="order-items-list">
              <% order.order_items.each do |item| %>
                <li>
                  <span class="item-main"><strong><%= item.quantity %>x</strong> <%= item.product&.name || item.combo&.name %></span>
                  <span class="item-price"><%= money(item.total_cents) %></span>
                </li>
              <% end %>
            </ul>
          </section>

          <section class="queue-section">
            <p class="section-title mb-1">Observações</p>
            <% item_notes = order.order_items.filter_map { |item| item.notes.to_s.strip.presence } %>
            <% if item_notes.any? %>
              <ul class="notes-list">
                <% item_notes.each do |note| %>
                  <li><%= note %></li>
                <% end %>
              </ul>
            <% else %>
              <p class="text-secondary mb-0">Não há observações para este pedido</p>
            <% end %>
          </section>
        </div>

        <div class="queue-card-footer">
          <div class="d-flex gap-1 justify-content-end">
            <% if order.received? %>
              <%= button_to start_production_admin_order_path(order), method: :post, class: "btn btn-sm btn-outline-brand icon-btn" do %>
                <%= ui_icon(:clock) %>
                <span>Iniciar</span>
              <% end %>
            <% elsif order.in_production? %>
              <%= button_to finish_admin_order_path(order), method: :post, class: "btn btn-sm btn-outline-brand icon-btn" do %>
                <%= ui_icon(:check) %>
                <span>Pronto</span>
              <% end %>
            <% elsif order.ready? %>
              <%= button_to mark_delivered_admin_order_path(order), method: :post, class: "btn btn-sm btn-outline-brand icon-btn" do %>
                <%= ui_icon(:check) %>
                <span>Finalizar</span>
              <% end %>
            <% end %>
          </div>
        </div>
      </article>
    <% end %>
  </section>
</div>
