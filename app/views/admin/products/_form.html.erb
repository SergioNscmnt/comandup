<%= form_with model: product, url: form_url, method: form_method, class: "admin-modal-form mt-3", data: { turbo_frame: "_top", controller: "currency-mask" } do |f| %>
  <div class="row g-2">
    <div class="col-12">
      <label class="form-label mb-1">Nome</label>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-md-4">
      <label class="form-label mb-1">Valor (R$)</label>
      <%= f.text_field :price_reais, class: "form-control", placeholder: "Ex: 19,90", required: true, inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-8">
      <label class="form-label mb-1">Categoria</label>
      <%= f.select :category_id, options_from_collection_for_select(categories, :id, :name, product.category_id), { prompt: "Selecione uma categoria" }, class: "form-select", required: true %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">Descrição</label>
      <%= f.text_area :description, class: "form-control", rows: 3 %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">URL da imagem</label>
      <%= f.url_field :image_url, class: "form-control", placeholder: "https://..." %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">Status</label>
      <%= f.select :active, [["Disponível", true], ["Indisponível", false]], {}, class: "form-select" %>
    </div>

    <div class="col-12">
      <hr class="my-2">
      <h3 class="h6 mb-1"><%= ui_icon(:receipt) %> Custos de produção</h3>
      <p class="text-secondary small mb-0">Esses custos alimentam o financeiro e o simulador de margem.</p>
    </div>

    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Ingredientes (R$)</label>
      <%= text_field_tag "product_cost[ingredients_reais]", cost_fields[:ingredients_reais], class: "form-control", inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Embalagem (R$)</label>
      <%= text_field_tag "product_cost[packaging_reais]", cost_fields[:packaging_reais], class: "form-control", inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Perdas (%)</label>
      <%= text_field_tag "product_cost[losses_percent]", cost_fields[:losses_percent], class: "form-control", inputmode: "decimal", placeholder: "Ex: 5,00" %>
    </div>
    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Mão de obra (R$)</label>
      <%= text_field_tag "product_cost[labor_reais]", cost_fields[:labor_reais], class: "form-control", inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Rateio fixo (R$)</label>
      <%= text_field_tag "product_cost[fixed_allocation_reais]", cost_fields[:fixed_allocation_reais], class: "form-control", inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-6">
      <label class="form-label mb-1">Taxa canal (%)</label>
      <%= text_field_tag "product_cost[channel_fee_percent]", cost_fields[:channel_fee_percent], class: "form-control", inputmode: "decimal", placeholder: "Ex: 12,00" %>
    </div>
  </div>

  <div class="admin-modal-actions mt-3">
    <%= f.button class: "btn btn-brand icon-btn" do %>
      <%= ui_icon(:check) %>
      <span><%= submit_label %></span>
    <% end %>
  </div>
<% end %>
