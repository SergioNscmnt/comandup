<div class="container-fluid queue-admin-container py-4 py-lg-5">
  <section class="section-head fade-in-up d-flex flex-wrap justify-content-between gap-3 align-items-end">
    <div>
      <p class="eyebrow mb-1">Operação</p>
      <h1 class="h2 mb-1"><%= ui_icon(:list) %> Fila de produção</h1>
      <p class="text-secondary mb-0">Ordenação FIFO com prioridade visual para os pedidos mais antigos.</p>
    </div>
    <div class="d-flex align-items-center gap-2">
      <%= form_with url: admin_queue_path, method: :get, local: true, class: "d-flex align-items-center gap-2", data: { controller: "autosubmit" } do %>
        <label for="order_type" class="mb-0 text-secondary">Tipo:</label>
        <%= select_tag :order_type, options_for_select([["Todos", ""], ["Mesa", "table"], ["Retirada", "pickup"], ["Delivery", "delivery"]], @filter), class: "form-select form-select-sm", data: { action: "change->autosubmit#submit" } %>
      <% end %>
      <div class="queue-count">
        <span><%= @orders.size %></span>
        <small>em aberto</small>
      </div>
    </div>
  </section>

  <section class="queue-list queue-list--admin mt-3">
    <% @orders.each_with_index do |order, index| %>
      <% item_notes = order.order_items.filter_map { |item| item.notes.to_s.strip.presence } %>
      <% total_items = order.order_items.sum(&:quantity) %>
      <% action = if order.received?
                    { label: "Iniciar", path: start_production_admin_order_path(order), icon: :clock }
                  elsif order.in_production?
                    { label: "Pronto", path: finish_admin_order_path(order), icon: :check }
                  elsif order.ready?
                    { label: "Finalizar", path: mark_delivered_admin_order_path(order), icon: :check }
                  end %>
      <article class="queue-card queue-order-card queue-order-card--<%= order.status %> fade-in-up fade-delay-admin-<%= index % 8 %>">
        <div class="queue-order-card__header">
          <div class="queue-order-card__title">
            <span class="queue-rank">#<%= order.queue_position || index + 1 %></span>
            <div>
              <h2 class="h6 mb-0"><%= ui_icon(:receipt) %> Pedido #<%= order.id %></h2>
              <small class="text-secondary"><%= l(order.created_at, format: :short) %></small>
            </div>
          </div>
          <div class="queue-order-card__meta">
            <span class="status-pill status-<%= order.status %>"><%= ui_icon(:check) %> <%= order.human_status %></span>
            <span class="prep-chip prep-chip--eta"><%= ui_icon(:clock) %> ETA: <%= order.eta_minutes || '-' %> min</span>
          </div>
        </div>

        <div class="queue-order-card__facts">
          <span class="queue-fact"><strong>Tipo:</strong> <%= order.human_order_type %>
            <% if order.order_type_table? %>
              (Mesa <%= order.table_number %>)
            <% end %>
          </span>
          <span class="queue-fact"><strong>Itens:</strong> <%= total_items %></span>
          <span class="queue-fact"><strong>Total:</strong> <span class="fact-value--total"><%= money(order.total_cents) %></span></span>
          <% if order.order_type_delivery? %>
            <span class="queue-fact"><strong>Taxa entrega:</strong> <%= money(order.delivery_fee_cents) %></span>
          <% end %>
          <% if order.customer.present? %>
            <span class="queue-fact"><strong>Cliente:</strong> <%= order.customer.name %></span>
          <% end %>
        </div>

        <section class="queue-order-card__items">
          <p class="section-title mb-1">Itens</p>
          <ul class="order-items-list">
            <% order.order_items.each do |item| %>
              <li>
                <span class="item-main"><strong><%= item.quantity %>x</strong> <%= item.product&.name || item.combo&.name %></span>
                <span class="item-price"><%= money(item.total_cents) %></span>
              </li>
            <% end %>
          </ul>
        </section>

        <details class="queue-details">
          <summary>Detalhes</summary>
          <% if order.customer.present? %>
            <p class="text-secondary mb-1"><strong>Contato:</strong> <%= order.customer.email %></p>
          <% end %>
          <% if order.order_type_delivery? && order.delivery_address.present? %>
            <p class="text-secondary mb-1"><strong>Endereço:</strong> <%= order.delivery_address %></p>
            <p class="text-secondary mb-1"><strong>Distância:</strong> <%= order.delivery_distance_km ? "#{order.delivery_distance_km} km" : "-" %></p>
          <% end %>
          <% if item_notes.any? %>
            <p class="text-secondary mb-1"><strong>Observações:</strong></p>
            <ul class="notes-list">
              <% item_notes.each do |note| %>
                <li><%= note %></li>
              <% end %>
            </ul>
          <% elsif !order.customer.present? && !(order.order_type_delivery? && order.delivery_address.present?) %>
            <p class="text-secondary mb-0">Sem detalhes adicionais.</p>
          <% end %>
        </details>

        <% if action %>
          <div class="queue-order-card__footer">
            <%= button_to action[:path], method: :post, class: "btn btn-sm btn-outline-brand icon-btn" do %>
              <%= ui_icon(action[:icon]) %>
              <span><%= action[:label] %></span>
            <% end %>
          </div>
        <% end %>
      </article>
    <% end %>
  </section>
</div>
