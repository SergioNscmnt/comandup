<div id="products-grid" class="row g-3 mt-2">
  <% @products.each_with_index do |product, index| %>
    <% current_qty = cart_quantity_for(product.id) %>
    <div class="col-12 col-md-6 col-xl-4">
      <article class="product-card fade-in-up fade-delay-<%= index % 6 %>">
        <div class="product-card__media">
          <% if product.image_url.present? %>
            <%= image_tag product.image_url, alt: "Imagem de #{product.name}", loading: "lazy", class: "product-card__image" %>
          <% else %>
            <div class="product-card__image-fallback" aria-hidden="true">
              <%= ui_icon(:box, class_name: "product-card__fallback-icon") %>
            </div>
          <% end %>
          <span class="price-chip product-card__price"><%= money(product.price_cents) %></span>
        </div>

        <div class="product-card__body">
          <div class="d-flex justify-content-between align-items-start gap-2">
            <h2 class="h5 mb-0"><%= product.name %></h2>
            <span class="status-dot <%= product.active? ? 'is-on' : 'is-off' %>">
              <%= product.active? ? ui_icon(:check) : ui_icon(:x) %>
              <%= product.active? ? "ativo" : "inativo" %>
            </span>
          </div>

          <p class="text-secondary mb-0 product-card__description"><%= product.description.presence || "Item do catálogo" %></p>
        </div>

        <div class="product-card__actions mt-3">
          <div class="product-quantity-control">
            <%= form_with url: cart_path(format: :turbo_stream), method: :patch, data: { turbo: true, turbo_stream: true }, class: "product-quantity-control__form" do %>
              <%= hidden_field_tag :product_id, product.id %>
              <%= hidden_field_tag :category_id, @selected_category_id %>

              <button type="submit" name="operation" value="decrease" class="btn btn-sm btn-outline-brand icon-btn" aria-label="<%= "Diminuir quantidade de #{product.name}" %>">
                <%= ui_icon(:dash) %>
              </button>

              <span class="product-quantity-value"><%= current_qty %></span>

              <button type="submit" name="operation" value="add" class="btn btn-sm btn-outline-brand icon-btn" aria-label="<%= "Aumentar quantidade de #{product.name}" %>">
                <%= ui_icon(:plus) %>
              </button>
            <% end %>
          </div>

          <% if current_admin %>
            <div class="product-card__admin-actions">
              <%= link_to edit_admin_product_path(product),
                          class: "btn btn-sm btn-outline-brand icon-btn",
                          data: { turbo_frame: "admin_catalog_modal" },
                          title: "Editar produto",
                          aria: { label: "Editar produto #{product.name}" } do %>
                <%= ui_icon(:edit) %>
              <% end %>

              <%= link_to admin_product_path(product),
                          class: "btn btn-sm btn-outline-danger icon-btn",
                          data: { turbo_method: :delete, turbo_confirm: "Excluir produto #{product.name}?" },
                          title: "Excluir produto",
                          aria: { label: "Excluir produto #{product.name}" } do %>
                <%= ui_icon(:trash) %>
              <% end %>
            </div>
          <% end %>
        </div>

        <% if current_qty.positive? %>
          <% note_field_id = "product-note-#{product.id}" %>
          <div class="mt-2" data-controller="note-toggle">
            <button type="button" class="btn btn-sm btn-outline-brand icon-btn" data-action="note-toggle#toggle">
              <span data-note-toggle-target="plusIcon"><%= ui_icon(:plus) %></span>
              <span data-note-toggle-target="dashIcon" hidden><%= ui_icon(:dash) %></span>
              <span data-note-toggle-target="label">Observação</span>
            </button>

            <div class="mt-2" data-note-toggle-target="panel" hidden>
              <%= form_with url: cart_path(format: :turbo_stream), method: :patch, data: { turbo: true, turbo_stream: true } do |f| %>
                <%= hidden_field_tag :product_id, product.id %>
                <%= hidden_field_tag :category_id, @selected_category_id %>
                <%= hidden_field_tag :operation, "note" %>
                <label class="form-label mb-1" for="<%= note_field_id %>">Observação do item</label>
                <%= text_area_tag :note, cart_note_for(product.id), id: note_field_id, class: "form-control", rows: 2, maxlength: 255, placeholder: "Ex: sem cebola, bem passado..." %>
                <div class="d-grid mt-2">
                  <%= f.submit "Salvar observação", class: "btn btn-sm btn-outline-brand justify-content-center" %>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </article>
    </div>
  <% end %>
</div>
