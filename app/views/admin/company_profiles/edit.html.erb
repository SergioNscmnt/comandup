<div class="container py-4 py-lg-5">
  <section class="hero-card fade-in-up">
    <h1 class="h4 mb-2"><%= ui_icon(:list) %> Endereço da empresa</h1>
    <p class="text-secondary mb-4">Esse endereço é usado como origem para calcular a taxa de delivery.</p>

    <%= form_with model: @company_account, url: admin_company_profile_path, method: :patch, local: true do |f| %>
      <div class="mb-3">
        <label class="form-label mb-1">Endereço completo da empresa</label>
        <%= f.text_field :company_address, class: "form-control", placeholder: "Ex: Av. Paulista, 1000 - Bela Vista, São Paulo - SP" %>
      </div>

      <div class="mb-3 col-12 col-md-4 p-0">
        <label class="form-label mb-1">CEP da empresa</label>
        <%= f.text_field :company_cep, class: "form-control", placeholder: "00000-000", maxlength: 9, inputmode: "numeric" %>
      </div>

      <%= f.button class: "btn btn-brand icon-btn" do %>
        <%= ui_icon(:check) %>
        <span>Salvar endereço</span>
      <% end %>
    <% end %>
  </section>
</div>
