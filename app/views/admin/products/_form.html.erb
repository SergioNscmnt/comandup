<%= form_with model: product, url: form_url, method: form_method, class: "admin-modal-form mt-3", data: { turbo_frame: "_top", controller: "currency-mask" } do |f| %>
  <div class="row g-2">
    <div class="col-12">
      <label class="form-label mb-1">Nome</label>
      <%= f.text_field :name, class: "form-control", required: true %>
    </div>
    <div class="col-12 col-md-4">
      <label class="form-label mb-1">Valor (R$)</label>
      <%= f.text_field :price_reais, class: "form-control", placeholder: "Ex: 19,90", required: true, inputmode: "numeric", data: { currency_mask_target: "field", action: "input->currency-mask#mask" } %>
    </div>
    <div class="col-12 col-md-8">
      <label class="form-label mb-1">Categoria</label>
      <%= f.select :category_id, options_from_collection_for_select(categories, :id, :name, product.category_id), { prompt: "Selecione uma categoria" }, class: "form-select", required: true %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">Descrição</label>
      <%= f.text_area :description, class: "form-control", rows: 3 %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">URL da imagem</label>
      <%= f.url_field :image_url, class: "form-control", placeholder: "https://..." %>
    </div>
    <div class="col-12">
      <label class="form-label mb-1">Status</label>
      <%= f.select :active, [["Disponível", true], ["Indisponível", false]], {}, class: "form-select" %>
    </div>
  </div>

  <div class="admin-modal-actions mt-3">
    <%= f.button class: "btn btn-brand icon-btn" do %>
      <%= ui_icon(:check) %>
      <span><%= submit_label %></span>
    <% end %>
  </div>
<% end %>
