<%= turbo_frame_tag "admin_catalog_modal" do %>
  <div class="admin-modal-backdrop" data-controller="frame-modal" data-action="click->frame-modal#closeIfBackdrop">
    <section class="admin-modal-card">
      <header class="admin-modal-head">
        <h2 class="h5 mb-0"><%= ui_icon(:box) %> Editar Produto</h2>
        <button type="button" class="btn btn-sm btn-outline-brand" data-action="frame-modal#close">Fechar</button>
      </header>

      <% if flash.now[:alert].present? %>
        <div class="alert alert-danger mt-3 mb-0"><%= flash.now[:alert] %></div>
      <% end %>

      <%= render "form",
                 product: @product,
                 cost_fields: @cost_fields,
                 categories: @categories,
                 form_url: admin_product_path(@product),
                 form_method: :patch,
                 submit_label: "Salvar alterações" %>
    </section>
  </div>
<% end %>
